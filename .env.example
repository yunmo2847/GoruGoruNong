# 서버/시드 스크립트 전용 (Node 측). 절대 src/ 클라이언트 코드에서 import 하지 말 것.
# 실제 값은 .env 로 복사(.env 는 .gitignore 됨).

# 정부 데이터 API 키 (승인 시 seed-baseline.ts 가 실연동에 사용)

# [필수] KOSIS: 발급 apiKey. baseline 재배면적의 실소스 — 없으면 전체 스냅샷 폴백
KOSIS_KEY=

# [가격] 아래 둘 중 하나. AT_SERVICE_KEY(공공데이터포털 aT 일별 도소매가) 우선.
#  - AT_SERVICE_KEY: data.go.kr 15156057 '일반 인증키(Decoding)'
#  - KAMIS_KEY + KAMIS_ID: KAMIS 직접 API (인증키 + 계정 아이디)
AT_SERVICE_KEY=
KAMIS_KEY=
KAMIS_ID=

# [생산량] MAFRA: data.mafra.go.kr 회원가입 시 자동 발급되는 인증키
MAFRA_KEY=

# [기후·병충해 위험도 알림] 4종 — 없으면 climateAlert.ts 결정적 mock으로 자동 폴백
APIHUB_KEY=
AMIS_KEY=
ARCCAS_KEY=
NCPMS_KEY=

# 인증 세션 서명 시크릿 (server 측에서만 사용)
JWT_SECRET=change-me-in-production

# 백엔드 포트 (vite proxy 대상과 일치해야 함)
PORT=5174
